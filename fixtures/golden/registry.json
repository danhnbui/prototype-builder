      "render": "return '<div style=\"min-height:100%;display:flex;align-items:center;justify-content:center;background:var(--bg-soft);padding:var(--space-8)\"><div style=\"width:var(--w-card);padding:var(--space-6);background:var(--surface);border:var(--border-width) solid var(--border);border-radius:var(--radius-medium)\"><h1 style=\"font-family:var(--font-heading);font-size:var(--text-xl);font-weight:700;margin:0 0 var(--space-5)\">Create account</h1><div class=\"field\" style=\"margin-bottom:var(--space-4)\"><input class=\"field__input\" data-handoff-el=\"email2\" type=\"text\" data-required data-validate=\"email\" placeholder=\"you@example.com\" style=\"width:100%;height:var(--size-field);padding:0 var(--space-3);border:var(--border-width) solid var(--border-strong);border-radius:var(--radius-small);font-family:var(--font-body);font-size:var(--text-sm)\" /></div><button data-handoff-el=\"create\" data-action=\"submit\" data-go=\"dashboard\" style=\"width:100%;height:var(--size-control);border:0;border-radius:var(--radius-small);background:var(--brand);color:var(--on-brand);font-family:var(--font-body);font-size:var(--text-sm);font-weight:600;cursor:pointer\">Create account</button><button data-nav=\"login\" style=\"display:block;margin-top:var(--space-4);background:none;border:0;color:var(--brand);font-family:var(--font-body);font-size:var(--text-sm);cursor:pointer\">Back to sign in</button></div></div>';"
