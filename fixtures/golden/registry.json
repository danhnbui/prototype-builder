{
  "_about": "Golden fixture — a clean, fully-tokenized 3-component / 3-screen dogfood project. CI renders this twice and asserts byte-identical output, checks render-time budget, and runs lint_registry.py --strict (must be CLEAN: no raw hex/px in render bodies, every orgId resolves, danger token present). e2e_smoke.py + test_sandbox.py boot it through serve.py. v1.4.3 layers the ADDITIVE roles + scenario-test contract on top (all optional; absence == pre-roles behavior): meta.roles/defaultRole, one role-gated screen (account -> admin), one data-roles element (dashboard admin control), and two runnable flow.stories[].scenarios[].test blocks (empty-submit-errors + valid-submit-navigates). Keep it token-only — it is the reference for Principle 2 (token-only styling) and must stay lint_registry.py --strict CLEAN.",
  "meta": {
    "name": "Acme Onboarding (golden)",
    "schemaVersion": 9,
    "entry": "prd",
    "platform": "web",
    "dsSource": null,
    "outputTier": "host",
    "exportTarget": null,
    "device": "desktop",
    "devices": [
      "desktop",
      "mobile"
    ],
    "roles": [
      {
        "id": "admin",
        "name": "Admin",
        "isAdmin": true,
        "description": "Full access — sees every screen and admin-only controls; bypasses all role gating."
      },
      {
        "id": "member",
        "name": "Member",
        "description": "Signed-in user. Manages their own account; admin-only screens and controls stay hidden."
      },
      {
        "id": "guest",
        "name": "Guest",
        "description": "Not signed in. Only public screens (e.g. sign-in); everything gated is hidden."
      }
    ],
    "defaultRole": "member",
    "designSystem": {
      "name": "Acme DS",
      "designLink": "https://www.figma.com",
      "codeLibrary": "https://github.com/danhnbui/prototype-builder",
      "linked": true
    },
    "overview": {
      "objectives": "Let new users create an account and reach their dashboard in under 60 seconds, validating the sign-up flow before production.",
      "principles": [
        {
          "num": 1,
          "title": "One job per screen",
          "body": "Each screen asks for exactly one decision or input set."
        },
        {
          "num": 2,
          "title": "Token-only styling",
          "body": "No raw hex or px — every value is a design token."
        },
        {
          "num": 3,
          "title": "Atomic composition",
          "body": "Build atoms then molecules then organisms then screens; never inline a one-off."
        }
      ]
    },
    "userInsights": {
      "quantitative": "62% of drop-off happens on the password step.",
      "researchSummary": "Users distrust forms that don't explain password rules up front.",
      "executiveSummary": "Reduce sign-up friction by surfacing validation inline."
    },
    "tradeoffs": [
      {
        "title": "Inline vs. on-submit validation",
        "question": "When do we validate?",
        "options": "Inline | On submit",
        "decision": "Inline",
        "why": "Catches errors before the user commits.",
        "tabsAffected": "Prototype, UX Design"
      }
    ],
    "others": null
  },
