      "logicNotes": ["Submit is disabled until both fields are valid.", "Successful submit redirects to the dashboard."],
      "render": "return '<div style=\"min-height:100%;display:flex;align-items:center;justify-content:center;background:var(--bg-soft);padding:var(--space-8)\"><div style=\"width:var(--w-card);padding:var(--space-6);background:var(--surface);border:var(--border-width) solid var(--border);border-radius:var(--radius-medium)\"><h1 style=\"font-family:var(--font-heading);font-size:var(--text-xl);font-weight:700;margin:0 0 var(--space-5)\">Sign in</h1><div class=\"field\" style=\"margin-bottom:var(--space-3)\"><input class=\"field__input\" data-handoff-el=\"email\" type=\"text\" data-required data-validate=\"email\" placeholder=\"you@example.com\" style=\"width:100%;height:var(--size-field);padding:0 var(--space-3);border:var(--border-width) solid var(--border-strong);border-radius:var(--radius-small);font-family:var(--font-body);font-size:var(--text-sm)\" /></div><div class=\"field\" style=\"margin-bottom:var(--space-4)\"><input class=\"field__input\" data-handoff-el=\"password\" type=\"password\" data-required data-minlength=\"8\" placeholder=\"Password\" style=\"width:100%;height:var(--size-field);padding:0 var(--space-3);border:var(--border-width) solid var(--border-strong);border-radius:var(--radius-small);font-family:var(--font-body);font-size:var(--text-sm)\" /></div><button data-handoff-el=\"submit\" data-action=\"submit\" data-go=\"dashboard\" style=\"width:100%;height:var(--size-control);border:0;border-radius:var(--radius-small);background:var(--brand);color:var(--on-brand);font-family:var(--font-body);font-size:var(--text-sm);font-weight:600;cursor:pointer\">Sign in</button><button data-nav=\"account\" style=\"display:block;margin-top:var(--space-4);background:none;border:0;color:var(--brand);font-family:var(--font-body);font-size:var(--text-sm);cursor:pointer\">Create an account</button></div></div>';"
    },
    {
      "id": "dashboard",
      "name": "Dashboard",
      "renderFn": "renderScreenDashboard",
