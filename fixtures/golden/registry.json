{
  "_about": "Golden fixture — a clean, fully-tokenized 3-component / 3-screen dogfood project. CI renders this twice and asserts byte-identical output, checks render-time budget, and runs check.py --strict (must be CLEAN: no raw hex/px in render bodies, every orgId resolves, danger token present). e2e_smoke.py boots it through serve.py. Keep it token-only — it is the reference for Principle 2 (token-only styling).",
  "meta": {
    "name": "Acme Onboarding (golden)",
    "schemaVersion": 3,
    "device": "desktop",
    "devices": ["desktop", "mobile"],
    "designSystem": {
      "name": "Acme DS",
      "designLink": "https://www.figma.com",
      "codeLibrary": "https://github.com/danhnbui/prototype-builder",
      "linked": true
    },
    "overview": {
      "objectives": "Let new users create an account and reach their dashboard in under 60 seconds, validating the sign-up flow before production.",
      "principles": [
        { "num": 1, "title": "One job per screen", "body": "Each screen asks for exactly one decision or input set." },
        { "num": 2, "title": "Token-only styling", "body": "No raw hex or px — every value is a design token." },
        { "num": 3, "title": "Atomic composition", "body": "Build atoms then molecules then organisms then screens; never inline a one-off." }
      ]
    },
    "userInsights": {
      "quantitative": "62% of drop-off happens on the password step.",
      "researchSummary": "Users distrust forms that don't explain password rules up front.",
      "executiveSummary": "Reduce sign-up friction by surfacing validation inline."
    },
    "tradeoffs": [
      { "title": "Inline vs. on-submit validation", "question": "When do we validate?", "options": "Inline | On submit", "decision": "Inline", "why": "Catches errors before the user commits.", "tabsAffected": "Prototype, UX Design" }
    ],
    "others": null
  },
