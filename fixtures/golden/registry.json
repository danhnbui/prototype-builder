  "components": [
    {
      "id": "button",
      "name": "Button",
      "renderFn": "renderCmpButton",
      "scope": "global",
      "level": "atom",
      "properties": [
        { "id": "label", "type": "string", "default": "Continue" },
        { "id": "state", "type": "enum", "default": "default", "options": [
          { "label": "Default", "value": "default" },
          { "label": "Disabled", "value": "disabled" }
        ] }
      ],
      "anatomy": "A pressable primary action.",
      "spec": "Control-height tall, brand fill, small radius.",
      "code": { "lang": "html", "snippet": "<button class=\"btn\">Continue</button>" },
      "uiLogic": ["Disabled while the form is invalid."],
      "render": "var dis = props.state === 'disabled' ? ' disabled' : ''; return '<button class=\"btn\" data-action=\"submit\"' + dis + ' style=\"height:var(--size-control);padding:0 var(--space-5);border:0;border-radius:var(--radius-small);background:var(--brand);color:var(--on-brand);font-family:var(--font-body);font-size:var(--text-sm);font-weight:600;cursor:pointer;opacity:' + (dis?'0.5':'1') + '\">' + (props.label || 'Continue') + '</button>';"
    },
    {
      "id": "text-input",
      "name": "TextInput",
      "renderFn": "renderCmpTextInput",
      "scope": "global",
      "level": "atom",
      "dsMatch": { "library": "Acme DS", "component": "Input" },
      "properties": [
        { "id": "placeholder", "type": "string", "default": "you@example.com" },
        { "id": "state", "type": "enum", "default": "default", "options": [
          { "label": "Default", "value": "default" },
          { "label": "Error", "value": "error" }
        ] }
      ],
      "anatomy": "A single-line text field with label.",
      "spec": "Full width, hairline border, brand focus ring.",
      "code": { "lang": "html", "snippet": "<input class=\"field\" />" },
      "uiLogic": ["Border turns to the danger token in the error state."],
      "render": "var err = props.state === 'error'; return '<input class=\"field\" type=\"text\" data-required placeholder=\"' + (props.placeholder || '') + '\" style=\"width:100%;height:var(--size-field);padding:0 var(--space-3);border:var(--border-width) solid ' + (err?'var(--danger)':'var(--border-strong)') + ';border-radius:var(--radius-small);font-family:var(--font-body);font-size:var(--text-sm)\" />';"
    },
    {
      "id": "login-card",
      "name": "User's Login Card",
      "renderFn": "renderCmpLoginCard",
      "scope": "local",
      "level": "organism",
      "properties": [
        { "id": "state", "type": "enum", "default": "default", "options": [
          { "label": "Default", "value": "default" },
          { "label": "Loading", "value": "loading" }
        ] }
      ],
      "anatomy": "Card wrapping the email + password fields and the submit button.",
      "spec": "Max card width, surface fill, medium radius, soft shadow.",
      "code": { "lang": "html", "snippet": "<div class=\"card\">…</div>" },
      "uiLogic": ["Shows a spinner in the loading state."],
      "render": "return '<div style=\"max-width:var(--w-card);padding:var(--space-6);background:var(--surface);border:var(--border-width) solid var(--border);border-radius:var(--radius-medium);box-shadow:var(--shadow-md)\"><h2 style=\"font-family:var(--font-heading);font-size:var(--text-lg);font-weight:600;margin:0 0 var(--space-4)\">Sign in</h2></div>';"
    }
  ],
