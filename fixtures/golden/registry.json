      ],
      "logicNotes": ["Landing screen after a successful sign-in."],
      "render": "return '<div style=\"min-height:100%;padding:var(--space-8);background:var(--bg-soft)\"><h1 style=\"font-family:var(--font-heading);font-size:var(--text-2xl);font-weight:700;margin:0 0 var(--space-2)\">Welcome back</h1><p style=\"font-family:var(--font-body);font-size:var(--text-sm);color:var(--text-muted)\">You are signed in.</p></div>';"
    },
