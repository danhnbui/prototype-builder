  "flow": {
    "populated": true,
    "mermaid": "flowchart LR\n  Start([Start]) --> Login[Login]\n  Login --> Valid{Valid?}\n  Valid -- No --> Login\n  Valid -- Yes --> Dashboard[Dashboard]\n  Dashboard --> End([End])",
    "screen": {
      "w": 1280,
      "h": 720
    },
    "stories": [
      {
        "title": "Sign in with email",
        "priority": "P1",
        "jtbd": "As a user I want to sign in so I can reach my dashboard.",
        "path": "Start → Login → Dashboard",
        "scenarios": [
          {
            "text": "Empty submit surfaces required-field errors before navigating.",
            "category": "function",
            "test": {
              "start": "login",
              "steps": [
                {
                  "do": "submit",
                  "target": "[data-action=\"submit\"]"
                }
              ],
              "expect": [
                {
                  "screen": "login"
                },
                {
                  "errors": {
                    "min": 2
                  }
                },
                {
                  "no-console-error": true
                }
              ]
            }
          },
          {
            "text": "Valid credentials land on the dashboard.",
            "category": "function",
            "test": {
              "start": "login",
              "steps": [
                {
                  "do": "fill",
                  "target": "[data-handoff-el=\"email\"]",
                  "value": "ada@example.com"
                },
                {
                  "do": "fill",
                  "target": "[data-handoff-el=\"password\"]",
                  "value": "hunter2hunter2"
                },
                {
                  "do": "submit",
                  "target": "[data-action=\"submit\"]"
                }
              ],
              "expect": [
                {
                  "screen": "dashboard"
                },
                {
                  "text": "Welcome back"
                },
                {
                  "no-console-error": true
                }
              ]
            }
          },
          {
            "text": "Invalid email shows an inline error with a danger border AND error text.",
            "category": "ui"
          }
        ]
      },
      {
        "title": "Recover from an error",
        "priority": "P2",
        "jtbd": "As a user I want clear feedback when my input is wrong.",
        "path": "Login → Valid? → Login",
        "scenarios": [
          {
            "text": "Error message clears once the field is corrected.",
            "category": "ui"
          }
        ]
      }
    ],
    "coverageWarnings": []
