{
  "schemaVersion": "2.0",
  "_comment": "Persistent contract for /pb:build-figma-handoff. Seeded at /pb:init; updated after every successful push. NEVER hand-edit between pushes. v2 (bridge): per-component `dsKey` is the DS component's PORTABLE publish key (what the GHN DS Bridge plugin rebuilds instances from) + name-keyed `propertyMapping`; file-local Figma node ids live under `_figma` and are used ONLY by the legacy Figma-MCP push ledger. registry_to_figma.py reads `dsKey`/`propertyMapping` (falling back to the ds-catalog) to emit INSTANCE nodes.",

  "target": {
    "fileKey": null,
    "fileUrl": null,
    "pageId": null,
    "pageName": null,
    "rootFrameId": null,
    "rootFrameName": null
  },

  "dsMatch": { "library": "{design-system}" },

  "lastScope": null,
  "lastPushedAt": null,
  "lastPushedHash": {
    "components": null,
    "screens": null
  },

  "components": {
    "_example_text-input": {
      "dsKey": "10:200",
      "dsMatch": {
        "library": "{design-system}",
        "componentName": "Input",
        "matchedAt": "0000-00-00T00:00:00Z",
        "matchedBy": "name"
      },
      "propertyMapping": {
        "placeholder": { "dsPropName": "Placeholder" },
        "state": { "dsPropName": "State", "options": { "default": "Default", "error": "Error" } }
      },
      "nestedInstances": {},
      "_figma": { "figmaComponentSetId": "1:33", "figmaId": "1:34", "figmaModifiedAt": null }
    }
  },

  "screens": {
    "_example_sign-in": {
      "lastPushedAt": "0000-00-00T00:00:00Z",
      "_figma": { "figmaFrameId": "1:50", "figmaModifiedAt": null,
        "elementMapping": { "title": "1:51", "emailFld": "1:52", "passwordFld": "1:53", "cta": "1:54" } }
    }
  },

  "decisions": {
    "defaultSizing": "hug-V,fill-H",
    "breakpoint": "375px",
    "tokenCollectionForLocalCreates": "Prototype tokens"
  }
}
